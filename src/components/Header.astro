---
import { isSameOriginReferrer } from "../utils/navigation";

const isHome = Astro.url.pathname === "/";
const canGoBack = isSameOriginReferrer(
  Astro.request.headers.get("referer"),
  Astro.url.origin,
);
---

<header class="topbar">
  <nav
    class={`topbar__nav${isHome ? " topbar__nav--home" : ""}`}
    aria-label="Primary"
  >
    <button
      class="topbar__back"
      type="button"
      aria-label={canGoBack ? "Go back" : "Return home"}
      data-can-go-back={canGoBack ? "true" : "false"}
      hidden={isHome}
    >
      <span aria-hidden="true">←</span>
    </button>
    <button
      class="topbar__toggle"
      type="button"
      aria-label="Toggle theme"
      title="Toggle theme"
    >
      <span class="topbar__toggleIcon" aria-hidden="true">☀︎</span>
    </button>
    <span class="topbar__spacer" aria-hidden="true"></span>
  </nav>
</header>

<script>
  import initHeader from "../scripts/header.ts";

  initHeader();
</script>
