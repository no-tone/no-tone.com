---
import NoteDate from "./NoteDate.astro";
import WindowLinks from "./WindowLinks.astro";

export interface Props {
  nonce?: string;
}

const { nonce } = Astro.props;
---

<div class="desktopWindow" data-desktop-window hidden>
  <div class="desktopWindow__backdrop" data-desktop-window-backdrop></div>
  <section
    class="desktopWindow__frame"
    data-desktop-window-frame
    aria-label="Desktop window"
  >
    <header class="desktopWindow__titlebar">
      <span class="desktopWindow__title" data-desktop-window-title>window/</span
      >
      <NoteDate
        nonce={nonce}
        className="desktopWindow__date"
        ariaLabel="Current local time"
      />
      <div class="desktopWindow__actions">
        <button
          class="desktopWindow__action"
          type="button"
          aria-label="Toggle theme"
          title="Toggle theme"
          data-desktop-window-theme
        >
          <span aria-hidden="true" data-desktop-window-theme-icon>☀︎</span>
        </button>
        <button
          class="desktopWindow__action"
          type="button"
          aria-label="Toggle fullscreen"
          title="Toggle fullscreen"
          data-desktop-window-fullscreen
        >
          <span aria-hidden="true">□</span>
        </button>
        <button
          class="desktopWindow__action"
          type="button"
          aria-label="Close window"
          title="Close window"
          data-desktop-window-close
        >
          <span aria-hidden="true">×</span>
        </button>
      </div>
    </header>
    <div class="desktopWindow__viewport">
      <iframe
        class="desktopWindow__iframe"
        title="Desktop window content"
        loading="eager"
        data-desktop-window-iframe></iframe>
    </div>
    <footer class="desktopWindow__footer">
      <WindowLinks className="desktopWindow__footerNav" />
    </footer>
  </section>
</div>
