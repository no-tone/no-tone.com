---
interface Props {
  className?: string;
}

const { className = "" } = Astro.props as Props;
const contactValue = "msg@no-tone.com";
---

<nav class={className} aria-label="Social">
  <a
    class="windowLinks__link"
    href="https://github.com/no-tone"
    target="_blank"
    rel="nofollow noreferrer noopener">github</a
  >
  <span class="windowLinks__sep" aria-hidden="true">/</span>
  <button
    class="windowLinks__link"
    type="button"
    data-copy-contact
    data-copy-value={contactValue}>contact</button
  >
</nav>
