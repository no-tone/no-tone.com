---
import "../styles/global.css";
import { SITE_DESCRIPTION, SITE_NAME, SITE_URL } from "../consts";

interface Props {
  title: string;
  description: string;
  image?: string;
  schema?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
  title,
  description,
  image = "/images/meta/og.png",
  schema,
} = Astro.props as Props;
const jbMonoFontUrl = import.meta.env.PUBLIC_JB_MONO_FONT_URL;
const fontOrigin = jbMonoFontUrl ? new URL(jbMonoFontUrl).origin : null;
const cspNonce = Astro.locals.cspNonce;

const canonicalURL = Astro.site
  ? new URL(Astro.url.pathname, Astro.site)
  : Astro.url;
const ogImageUrl = new URL(image, Astro.url);
const ogImageWidth = image === "/images/meta/og.png" ? "1200" : undefined;
const ogImageHeight = image === "/images/meta/og.png" ? "630" : undefined;
const schemaItems = Array.isArray(schema) ? schema : schema ? [schema] : [];
const defaultSchema = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: SITE_NAME,
    url: SITE_URL,
    description: SITE_DESCRIPTION,
    inLanguage: "en",
  },
  {
    "@context": "https://schema.org",
    "@type": "Person",
    name: SITE_NAME,
    url: SITE_URL,
    sameAs: ["https://github.com/n0-tone"],
    knowsAbout: [
      "Software engineering",
      "Full-stack development",
      "Cloudflare Workers",
      "Privacy engineering",
    ],
  },
];
const resolvedSchema = [...defaultSchema, ...schemaItems];
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" href="/favicon.ico" sizes="any" />
<link rel="icon" type="image/png" sizes="16x16" href="/icons/favicon-16x16.png" />
<link rel="icon" type="image/png" sizes="32x32" href="/icons/favicon-32x32.png" />
<link rel="apple-touch-icon" sizes="180x180" href="/icons/apple-touch-icon.png" />
<link rel="manifest" href="/site.webmanifest" />
<meta name="generator" content={Astro.generator} />
<meta name="robots" content="index,follow" />
<!-- Preconnect to Cloudflare Fonts origin -->
{
  fontOrigin && fontOrigin !== canonicalURL.origin && (
    <link rel="preconnect" href={fontOrigin} crossorigin="anonymous" />
  )
}

<!-- Cloudflare Fonts (JetBrains Mono Variable) -->
{jbMonoFontUrl && <link rel="stylesheet" href={jbMonoFontUrl} />}

<!-- Theme bootstrap (runs before first paint) -->
<script is:inline nonce={cspNonce}>
  (() => {
    const STORAGE_KEY = "theme";
    try {
      const stored = localStorage.getItem(STORAGE_KEY);
      const theme = stored === "light" || stored === "dark" ? stored : "dark";
      document.documentElement.dataset.theme = theme;
      if (stored !== theme) {
        localStorage.setItem(STORAGE_KEY, theme);
      }
    } catch {
      document.documentElement.dataset.theme = "dark";
    }
  })();
</script>

<!-- Shared client helpers -->
<script nonce={cspNonce}>
  import initSharedHead from "../scripts/shared-head.ts";

  initSharedHead();
</script>

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />
<link rel="alternate" hreflang="en" href={canonicalURL} />
<link rel="alternate" hreflang="x-default" href={canonicalURL} />

<!-- RSS Feed Discovery -->
<link rel="alternate" type="application/rss+xml" title="RSS" href="/rss.xml" />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:image:secure_url" content={ogImageUrl} />
{ogImageWidth && <meta property="og:image:width" content={ogImageWidth} />}
{ogImageHeight && <meta property="og:image:height" content={ogImageHeight} />}
<meta property="og:image:alt" content={`${SITE_NAME} preview`} />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={canonicalURL} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageUrl} />
<meta name="twitter:image:alt" content={`${SITE_NAME} preview`} />

<script
  type="application/ld+json"
  nonce={cspNonce}
  set:html={JSON.stringify(resolvedSchema)}
></script>
