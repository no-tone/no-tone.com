---
import globalCss from "../styles/global.css?inline";
import { SITE_DESCRIPTION, SITE_NAME, SITE_URL } from "../consts";

interface Props {
  title: string;
  description: string;
  image?: string;
  schema?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
  title,
  description,
  image = "/images/meta/og.png",
  schema,
} = Astro.props as Props;
const jbMonoFontUrl = import.meta.env.PUBLIC_JB_MONO_FONT_URL;
const fontOrigin = jbMonoFontUrl ? new URL(jbMonoFontUrl).origin : null;
const cspNonce = Astro.locals.cspNonce;

const canonicalURL = Astro.site
  ? new URL(Astro.url.pathname, Astro.site)
  : Astro.url;
const ogImageUrl = new URL(image, Astro.url);
const canonicalHref = canonicalURL.toString();
const ogImageHref = ogImageUrl.toString();
const ogImageWidth = image === "/images/meta/og.png" ? "1200" : undefined;
const ogImageHeight = image === "/images/meta/og.png" ? "630" : undefined;
const schemaItems = Array.isArray(schema) ? schema : schema ? [schema] : [];
const defaultSchema = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: SITE_NAME,
    url: SITE_URL,
    description: SITE_DESCRIPTION,
    inLanguage: "en",
  },
  {
    "@context": "https://schema.org",
    "@type": "Person",
    name: SITE_NAME,
    url: SITE_URL,
    sameAs: ["https://github.com/n0-tone"],
    knowsAbout: [
      "Software engineering",
      "Full-stack development",
      "Cloudflare Workers",
      "Privacy engineering",
    ],
  },
];
const resolvedSchema = [...defaultSchema, ...schemaItems];
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" href="/favicon.ico" sizes="any" />
<link
  rel="icon"
  type="image/png"
  sizes="16x16"
  href="/icons/favicon-16x16.png"
/>
<link
  rel="icon"
  type="image/png"
  sizes="32x32"
  href="/icons/favicon-32x32.png"
/>
<link
  rel="apple-touch-icon"
  sizes="180x180"
  href="/icons/apple-touch-icon.png"
/>
<link rel="manifest" href="/site.webmanifest" />
<meta name="generator" content={Astro.generator} />
<meta name="robots" content="index,follow" />
<style nonce={cspNonce} set:html={globalCss}></style>
<!-- Preconnect to Cloudflare Fonts origin -->
{
  fontOrigin && fontOrigin !== canonicalURL.origin && (
    <link rel="preconnect" href={fontOrigin} crossorigin="anonymous" />
  )
}

<!-- Cloudflare Fonts (JetBrains Mono Variable) -->
{jbMonoFontUrl && <link rel="stylesheet" href={jbMonoFontUrl} />}

<!-- Theme bootstrap (runs before first paint) -->
<script is:inline nonce={cspNonce}>
  (() => {
    const STORAGE_KEY = "theme";
    try {
      const stored = localStorage.getItem(STORAGE_KEY);
      const theme = stored === "light" || stored === "dark" ? stored : "dark";
      document.documentElement.dataset.theme = theme;
      if (stored !== theme) {
        localStorage.setItem(STORAGE_KEY, theme);
      }
    } catch {
      document.documentElement.dataset.theme = "dark";
    }
  })();
</script>

<!-- Shared client helpers -->
<script is:inline nonce={cspNonce}>
  (() => {
    const root = (window.noTone ??= {});
    const THEME_KEY = "theme";
    const copyResetTimers = new WeakMap();

    root.getStoredTheme = () => {
      try {
        const value = localStorage.getItem(THEME_KEY);
        return value === "light" || value === "dark" ? value : null;
      } catch {
        return null;
      }
    };

    root.setStoredTheme = (theme) => {
      root.applyTheme(theme);
      try {
        localStorage.setItem(THEME_KEY, theme);
      } catch {
        // no-op
      }
      window.dispatchEvent(
        new CustomEvent("no-tone:themechange", {
          detail: { theme },
        }),
      );
    };

    root.readTheme = () =>
      root.getStoredTheme() ??
      (document.documentElement.dataset.theme === "dark" ? "dark" : "light");

    root.applyTheme = (theme) => {
      document.documentElement.dataset.theme = theme;
    };

    root.syncTheme = (theme) => {
      const resolved =
        theme === "light" || theme === "dark" ? theme : root.readTheme();
      root.applyTheme(resolved);
      try {
        localStorage.setItem(THEME_KEY, resolved);
      } catch {
        // no-op
      }
      return resolved;
    };

    root.isSafeExternalUrl = (value) => {
      try {
        const raw = String(value || "").trim();
        if (!raw) return false;
        const url = new URL(raw);
        return url.protocol === "http:" || url.protocol === "https:";
      } catch {
        return false;
      }
    };

    root.openExternal = (url) => {
      if (!root.isSafeExternalUrl(url)) return;
      window.open(String(url), "_blank", "noopener,noreferrer");
    };

    document.addEventListener("click", async (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;
      const button = target.closest("[data-copy-contact]");
      if (!(button instanceof HTMLButtonElement)) return;

      const value = button.dataset.copyValue || "";
      if (!value) return;

      try {
        await navigator.clipboard.writeText(value);
        button.textContent = "copied";
      } catch {
        button.textContent = "failed";
      }

      const currentReset = copyResetTimers.get(button);
      if (currentReset) {
        window.clearTimeout(currentReset);
      }

      const resetTimer = window.setTimeout(() => {
        button.textContent = "contact";
        copyResetTimers.delete(button);
      }, 1200);
      copyResetTimers.set(button, resetTimer);
    });

    window.addEventListener("no-tone:themechange", (event) => {
      if (!(event instanceof CustomEvent)) return;
      root.syncTheme(event.detail?.theme);
    });

    window.addEventListener("message", (event) => {
      if (event.origin !== window.location.origin) return;
      const data = event.data;
      if (!data || typeof data !== "object") return;
      if (data.type !== "no-tone:set-theme") return;
      root.syncTheme(data.theme);
    });
  })();
</script>

<!-- Canonical URL -->
<link rel="canonical" href={canonicalHref} />
<link rel="alternate" hreflang="en" href={canonicalHref} />
<link rel="alternate" hreflang="x-default" href={canonicalHref} />

<!-- RSS Feed Discovery -->
<link rel="alternate" type="application/rss+xml" title="RSS" href="/rss.xml" />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalHref} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImageHref} />
<meta property="og:image:secure_url" content={ogImageHref} />
{ogImageWidth && <meta property="og:image:width" content={ogImageWidth} />}
{ogImageHeight && <meta property="og:image:height" content={ogImageHeight} />}
<meta property="og:image:alt" content={`${SITE_NAME} preview`} />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={canonicalHref} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageHref} />
<meta name="twitter:image:alt" content={`${SITE_NAME} preview`} />

<script
  type="application/ld+json"
  nonce={cspNonce}
  set:html={JSON.stringify(resolvedSchema)}
/>
