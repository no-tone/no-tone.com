---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import SiteEffects from "../components/SiteEffects.astro";
const windowMode = Astro.url.searchParams.get("window") === "1";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title="no-tone | 404"
      description="The page you were looking for does not exist. Browse projects, tldr notes, or the usr directory instead."
    />
  </head>
  <body
    data-window-mode={windowMode ? "true" : undefined}
    data-standalone-window={!windowMode ? "true" : undefined}
  >
    {!windowMode && <Header />}
    <main class="note note--error" data-window-root>
      <div class="note__content">
        <p>
          This is a broken link, or the page you were trying to open no longer
          exists.
        </p>
        <p>
          Try <a href="/projects/">/projects/</a>, <a href="/tldr/">/tldr/</a>,
          or <a href="/usr/">/usr/</a>.
        </p>
      </div>
    </main>
    {!windowMode && <Footer />}
    <SiteEffects />
  </body>
</html>
