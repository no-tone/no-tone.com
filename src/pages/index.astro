---
import BaseHead from "../components/BaseHead.astro";
import { SITE_DESCRIPTION, SITE_TITLE, SITE_URL } from "../consts";
// Design system, split into modules and concatenated so BaseHead can inline
// it under the CSP nonce (a single same-origin <style>, no external sheet).
import tokensCss from "../styles/desktop/tokens.css?inline";
import baseCss from "../styles/desktop/base.css?inline";
import componentsCss from "../styles/desktop/components.css?inline";
import chromeCss from "../styles/desktop/chrome.css?inline";
import panelsCss from "../styles/desktop/panels.css?inline";
import responsiveCss from "../styles/desktop/responsive.css?inline";
const desktopCss = [
  tokensCss,
  baseCss,
  componentsCss,
  chromeCss,
  panelsCss,
  responsiveCss,
].join("\n");

const homeSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: SITE_TITLE,
  url: SITE_URL,
  description: SITE_DESCRIPTION,
  about: [
    "projects",
    "GitHub repositories",
    "curriculum vitae",
    "software engineering",
    "Cloudflare Workers",
  ],
};

// Globe / rail navigation. `panel` nodes open the slide-over drawer;
// `link` nodes go external. Labels are set (and localized) client-side.
const NODES = [
  { id: "projects", label: "projects", type: "panel" },
  { id: "cv", label: "cv", type: "panel" },
  { id: "about", label: "about", type: "panel" },
  { id: "contact", label: "contact", type: "link" },
  { id: "github", label: "github", type: "link" },
];
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <BaseHead
      title={SITE_TITLE}
      description={SITE_DESCRIPTION}
      schema={homeSchema}
      css={desktopCss}
      viewport="width=device-width, initial-scale=1, viewport-fit=cover"
      defaultFont={false}
    />
    <!-- Hanken Grotesk (UI/body) + Yeseva One (display), self-hosted under
         /fonts. @font-face is in the inlined (nonce'd) desktop CSS; preloading
         the woff2 avoids a flash of fallback text. -->
    <link
      rel="preload"
      href="/fonts/hanken-grotesk-var.woff2"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />
    <link
      rel="preload"
      href="/fonts/yeseva-400.woff2"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />
  </head>
  <body>
    <!-- SEO / no-JS: the desktop is a canvas app, so expose the map in text. -->
    <section class="sr-only">
      <h1>no-tone — a desktop of tools, experiments and marks in the making</h1>
      <p>
        Navigate the globe or the index: projects, cv, about, contact and
        github. no-tone is the workshop of a software engineer.
      </p>
      <ul>
        <li><a href="https://github.com/no-tone">github</a></li>
        <li><a href="mailto:msg@no-tone.com">contact — msg@no-tone.com</a></li>
      </ul>
    </section>

    <main class="vk" aria-label="no-tone desktop">
      <canvas class="vk-canvas" id="vk-canvas" aria-hidden="true"></canvas>

      <!-- globe nodes: a decorative, non-focusable overlay (the rail below
           is the real, keyboard-accessible nav), so aria-hidden here is safe -->
      <div class="vk-nodes" id="vk-nodes" aria-hidden="true">
        {
          NODES.map((n) => (
            <div class="vk-node" data-node={n.id} data-type={n.type}>
              <span
                class="vk-node__label"
                data-i18n={n.id}
                data-arrow={n.type === "link" ? "" : undefined}
              >
                {n.label}
                {n.type === "link" ? " ↗" : ""}
              </span>
            </div>
          ))
        }
      </div>

      <!-- wordmark — click toggles theme -->
      <button
        class="vk-word"
        id="vk-word"
        type="button"
        title="toggle theme"
        aria-label="toggle theme"
      >
        no-tone<span class="vk-word__globe" aria-hidden="true"></span>
      </button>

      <!-- top chrome: coordinate readout + status -->
      <div class="vk-top">
        <div class="vk-coord" id="vk-coord" aria-hidden="true">
          <div>X:<b id="vk-x">0000</b></div>
          <div>Y:<b id="vk-y">0000</b></div>
        </div>
        <span class="vk-status">
          <span class="vk-status__dot" aria-hidden="true"></span>
          <span data-i18n="status">heads-down · building</span>
        </span>
      </div>

      <!-- left index rail (mirrors globe nav) + signature swatches -->
      <nav class="vk-rail" aria-label="index">
        <span class="vk-rail__k" data-i18n="index">index</span>
        <div class="vk-rail__nav">
          {
            NODES.map((n) => (
              <button class="vk-rail__item" type="button" data-node={n.id} data-type={n.type}>
                <span class="vk-rail__tick" aria-hidden="true" />
                <span data-i18n={n.id} data-arrow={n.type === "link" ? "" : undefined}>
                  {n.label}
                  {n.type === "link" ? " ↗" : ""}
                </span>
              </button>
            ))
          }
        </div>
        <div class="vk-rail__sig">
          <span class="vk-rail__k" data-i18n="signature">signature</span>
          <div class="vk-swatches" id="vk-swatches"></div>
        </div>
      </nav>

      <!-- bottom chrome: clocks + language toggle -->
      <div class="vk-bottom">
        <span class="vk-clock"
          ><span data-i18n="cityLondon">london</span>
          <b id="vk-clock-london">--:--</b></span
        >
        <div class="vk-lang" role="group" aria-label="language">
          <button type="button" data-lang="en" class="is-on">en</button>
          <span aria-hidden="true">/</span>
          <button type="button" data-lang="pt">pt</button>
        </div>
        <span class="vk-clock"
          ><span data-i18n="citySf">san francisco</span>
          <b id="vk-clock-sf">--:--</b></span
        >
      </div>

      <!-- slide-over drawer -->
      <div class="vk-drawer" id="vk-drawer">
        <div class="vk-backdrop" id="vk-backdrop"></div>
        <div class="vk-sheet" role="dialog" aria-modal="true" aria-label="panel">
          <button class="vk-close" id="vk-close" type="button" aria-label="close">×</button>
          <div class="vk-sheet__body" id="vk-sheet-body"></div>
          <button class="vk-btt" id="vk-btt" type="button" aria-label="back to top">↑</button>
        </div>
      </div>
    </main>

    <script>
      import "../scripts/desktop/main";
    </script>
  </body>
</html>
