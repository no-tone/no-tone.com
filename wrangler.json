{
  "name": "no-tone",
  "main": "./src/worker.ts",
  "compatibility_date": "2025-10-08",
  "compatibility_flags": ["nodejs_compat", "disable_nodejs_process_v2"],
  "triggers": {
    "crons": ["*/10 * * * *"]
  },
  "vars": {
    "SITE_ORIGIN": "https://no-tone.com"
  },
  "workers_dev": false,
  "preview_urls": false,
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  },
  "env": {
    "dev": {
      "name": "no-tone-dev",
      "vars": {
        "SITE_ORIGIN": "https://dev.no-tone.com"
      }
    }
  },
  "upload_source_maps": true,
  "send_metrics": false
}
