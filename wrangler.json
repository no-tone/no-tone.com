{
  "name": "no-tone",
  "main": "./src/worker.ts",
  "compatibility_date": "2025-10-08",
  "compatibility_flags": ["nodejs_compat", "disable_nodejs_process_v2"],
  "triggers": {
    "crons": ["*/10 * * * *"]
  },
  "workers_dev": false,
  "preview_urls": false,
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  },
  "upload_source_maps": true,
  "send_metrics": false
}
